<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Cat Service - Error</title>
    <style>
        body {
            font-family: "Times New Roman", Times, serif;
            background-color: #c0c0c0;
            margin: 0;
            padding: 0;
        }
        .error-container {
            width: 450px;
            margin: 100px auto;
            border: 2px outset #ffffff;
            background-color: #e0e0e0;
            padding: 20px;
            text-align: center;
        }
        h1 {
            font-size: 22px;
            color: #cc0000;
            margin: 10px 0;
        }
        p {
            color: #000000;
            font-size: 14px;
        }
        a {
            color: #0000ee;
        }
        a:visited {
            color: #551a8b;
        }
        hr {
            border: none;
            border-top: 1px solid #808080;
            border-bottom: 1px solid #ffffff;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <h1>Error</h1>
        <hr>
        <p><%= message %></p>
        <hr>
        <p><a href="/login">Go back to login</a></p>
    </div>
</body>
</html>
